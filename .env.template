# ── W&B account ───────────────────────────────────────────────────────────────
# Your W&B entity (username or team name shown after `wandb login`).
WANDB_ENTITY=your_username_or_team

# Self-hosted server only — omit this line when using wandb.ai cloud.
# WANDB_BASE_URL=http://<host>:8080

# API key — not required when credentials are stored via `wandb login`.
# Set only to override the key stored in ~/.netrc.
# WANDB_API_KEY=your_api_key_here

# ── GPU / tokenizer ───────────────────────────────────────────────────────────
CUDA_VISIBLE_DEVICES=0
TOKENIZERS_PARALLELISM=false
